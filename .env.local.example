# Supabase credentials
# Sign up at https://supabase.com/ and create a new project
# Then copy the URL and anon key from the API settings

NEXT_PUBLIC_SUPABASE_URL=https://your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# After setting up the project, you need to:
# 1. Create a storage bucket named 'gallery'
# 2. Create a table named 'shapeset_gallery' with the following columns:
#    - id: uuid (primary key, default: gen_random_uuid())
#    - filename: text
#    - shape_colors: jsonb
#    - background_color: text
#    - rows: integer
#    - cols: integer
#    - created_at: timestamp with time zone (default: now())
