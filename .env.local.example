# Supabase credentials
# Sign up at https://supabase.com/ and create a new project
# Then copy the URL and anon key from the API settings

NEXT_PUBLIC_SUPABASE_URL=https://your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic API Key for AI Tutor
# Sign up at https://console.anthropic.com/ and get your API key
# IMPORTANT: Never expose this key to the client!
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# After setting up the project, you need to:
# 1. Create a storage bucket named 'gallery'
# 2. Run the SQL migrations in /db/migrations/:
#    - create-ai-tutor-tables.sql (for AI tutor functionality)
# 3. Set up existing tables (see db/migrations/ for other SQL files)
